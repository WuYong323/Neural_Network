   "source": [
    "from value import Value,draw_dot\n",
    "\n",
    "a = Value(-3)\n",
    "a.label = 'a'\n",
    "b = Value(4)\n",
    "b.label = 'b'\n",
    "c = Value(15)\n",
    "c.label = 'c'\n",
    "f = a * b + c\n",
    "f.label = 'f'\n",
    "g=f.tanh()\n",
    "g.backward()\n",
    "draw_dot(g).view()"
   ],
